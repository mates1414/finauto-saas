# FinAuto SaaS API — example configuration. Copy to `.env` and fill in locally.
# Never commit a real `.env` (it is gitignored; the workspace secrets hook enforces this).

# --- App ---
APP_NAME=FinAuto SaaS API
DEBUG=false

# --- Security / Auth ---
# Generate a long random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database (SQLite default; use Postgres in prod) ---
DATABASE_URL=sqlite:///./finauto_saas.db

# --- Task queue: "in_memory" (local dev) or "arq" (needs Redis) ---
QUEUE_PROVIDER=in_memory
REDIS_URL=redis://localhost:6379

# --- Storage: "local" or "s3" ---
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage_data
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- CORS: comma-separated allowed frontend origins ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Damodaran industry-beta workbook (optional; auto-located next to finauto if unset) ---
# DAMODARAN_BETA_PATH=../../finauto/betaemerg.xls

# --- LLM keys (fall back to finauto's own env if omitted) ---
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
